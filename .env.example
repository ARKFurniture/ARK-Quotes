# ARK Furniture Quote System — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend API key (from resend.com/api-keys)
RESEND_API_KEY=your_resend_api_key_here

# Email address to receive approval notifications (usually same as your sending address)
NOTIFY_EMAIL=info@arkfurniture.ca

# Dashboard API key — make this a long random string
# Generate one at: https://randomkeygen.com (use "Fort Knox Passwords")
DASHBOARD_API_KEY=your_long_random_key_here

# Your Fly.io app URL
DASHBOARD_URL=https://ark-quotes.fly.dev

# SQLite database path (Fly.io volume)
DB_PATH=/data/ark.db

# Port (Fly.io sets this automatically)
PORT=3000
